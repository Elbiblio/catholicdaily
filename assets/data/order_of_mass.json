  {
    "id": "greeting",
    "title": "Greeting",
    "insertionPoint": "introductory_rites",
    "order": 2,
    "availableLanguages": ["en", "la", "es", "pt", "fr", "tl", "it", "pl", "vi", "ko"],
    "conditions": ["always"],
    "isOptional": false,
    "isDialogue": true,
    "dialogueStructure": {
      "en": [
        {"text": "The Lord be with you.", "role": "priest", "prefix": "V"},
        {"text": "And with your spirit.", "role": "people", "prefix": "R"}
      ],
      "la": [
        {"text": "Dóminus vobíscum.", "role": "priest", "prefix": "V"},
        {"text": "Et cum spíritu tuo.", "role": "people", "prefix": "R"}
      ],
      "es": [
        {"text": "El Señor esté con ustedes.", "role": "priest", "prefix": "V"},
        {"text": "Y con tu espíritu.", "role": "people", "prefix": "R"}
      ],
      "pt": [
        {"text": "O Senhor esteja convosco.", "role": "priest", "prefix": "V"},
        {"text": "E com o vosso espírito.", "role": "people", "prefix": "R"}
      ],
      "fr": [
        {"text": "Le Seigneur soit avec vous.", "role": "priest", "prefix": "V"},
        {"text": "Et avec votre esprit.", "role": "people", "prefix": "R"}
      ],
      "tl": [
        {"text": "Ang Panginoon ay sumainyo.", "role": "priest", "prefix": "V"},
        {"text": "At sa iyong espiritu.", "role": "people", "prefix": "R"}
      ],
      "it": [
        {"text": "Il Signore sia con voi.", "role": "priest", "prefix": "V"},
        {"text": "E con il tuo spirito.", "role": "people", "prefix": "R"}
      ],
      "pl": [
        {"text": "Pan niech z wami.", "role": "priest", "prefix": "V"},
        {"text": "I z duchem Twoim.", "role": "people", "prefix": "R"}
      ],
      "vi": [
        {"text": "Chúa trên phù cùng anh em.", "role": "priest", "prefix": "V"},
        {"text": "Và cùng Thánh Thánh anh em.", "role": "people", "prefix": "R"}
      ],
      "ko": [
        {"text": "Jesu Kristo wa, hyangja nim.", "role": "priest", "prefix": "V"},
        {"text": "Geurigo sseonghona nim.", "role": "people", "prefix": "R"}
      ]
    },
    "contentByLanguage": {
      "en": [
        "The Lord be with you.",
        "And with your spirit."
      ],
      "la": [
        "Dóminus vobíscum.",
        "Et cum spíritu tuo."
      ],
      "es": [
        "El Señor esté con ustedes.",
        "Y con tu espíritu."
      ],
      "pt": [
        "O Senhor esteja convosco.",
        "E com o vosso espírito."
      ],
      "fr": [
        "Le Seigneur soit avec vous.",
        "Et avec votre esprit."
      ],
      "tl": [
        "Ang Panginoon ay sumainyo.",
        "At sa iyong espiritu."
      ]
    }
  },
