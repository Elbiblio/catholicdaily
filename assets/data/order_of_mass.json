  {
    "id": "preface_dialogue",
    "title": "Preface Dialogue",
    "insertionPoint": "preface",
    "order": 1,
    "availableLanguages": ["en", "la", "es", "pt", "fr", "tl", "it", "pl", "vi", "ko"],
    "conditions": ["always"],
    "isOptional": false,
    "isDialogue": true,
    "dialogueStructure": {
      "en": [
        {"text": "The Lord be with you.", "role": "priest", "prefix": "V"},
        {"text": "And with your spirit.", "role": "people", "prefix": "R"},
        {"text": "Lift up your hearts.", "role": "priest", "prefix": "V"},
        {"text": "We lift them up to the Lord.", "role": "people", "prefix": "R"},
        {"text": "Let us give thanks to the Lord our God.", "role": "priest", "prefix": "V"},
        {"text": "It is right and just.", "role": "people", "prefix": "R"}
      ],
      "la": [
        {"text": "Dóminus vobíscum.", "role": "priest", "prefix": "V"},
        {"text": "Et cum spíritu tuo.", "role": "people", "prefix": "R"},
        {"text": "Sursum corda.", "role": "priest", "prefix": "V"},
        {"text": "Habémus ad Dóminum.", "role": "people", "prefix": "R"},
        {"text": "Grátias agámus Dómino Deo nostro.", "role": "priest", "prefix": "V"},
        {"text": "Dignum et iustum est.", "role": "people", "prefix": "R"}
      ],
      "it": [
        {"text": "Il Signore sia con voi.", "role": "priest", "prefix": "V"},
        {"text": "E con il tuo spirito.", "role": "people", "prefix": "R"},
        {"text": "In alto i cuori.", "role": "priest", "prefix": "V"},
        {"text": "Sono rivolti al Signore.", "role": "people", "prefix": "R"},
        {"text": "Rendiamo grazie al Signore nostro Dio.", "role": "priest", "prefix": "V"},
        {"text": "È cosa giusta e buona.", "role": "people", "prefix": "R"}
      ],
      "pl": [
        {"text": "Pan niech z wami.", "role": "priest", "prefix": "V"},
        {"text": "I z duchem Twoim.", "role": "people", "prefix": "R"},
        {"text": "Wzniecie serca.", "role": "priest", "prefix": "V"},
        {"text": "Wznieserzyli je do Pana.", "role": "people", "prefix": "R"},
        {"text": "Dzi?kujmy Panu Bogu naszemu.", "role": "priest", "prefix": "V"},
        {"text": "Warte i sprawiedliwe.", "role": "people", "prefix": "R"}
      ],
      "vi": [
        {"text": "Chúa trên phù cùng anh em.", "role": "priest", "prefix": "V"},
        {"text": "Và cùng Thánh Thánh anh em.", "role": "people", "prefix": "R"},
        {"text": "Hãy nâng tâm trí lên.", "role": "priest", "prefix": "V"},
        {"text": "Chúng con nâng lên cùng Chúa.", "role": "people", "prefix": "R"},
        {"text": "Chúng ta tôn kính Chúa.", "role": "priest", "prefix": "V"},
        {"text": "Thích ?úng và công chính.", "role": "people", "prefix": "R"}
      ],
      "ko": [
        {"text": "Jesu Kristo wa, hyangja nim.", "role": "priest", "prefix": "V"},
        {"text": "Geurigo sseonghona nim.", "role": "people", "prefix": "R"},
        {"text": "Maeum-eul deulgi.", "role": "priest", "prefix": "V"},
        {"text": "Hananim-ege deulgo.", "role": "people", "prefix": "R"},
        {"text": "Hananim-ege gamsahanda.", "role": "priest", "prefix": "V"},
        {"text": "Gwa-uihago jeonguihanda.", "role": "people", "prefix": "R"}
      ]
    },
    "contentByLanguage": {
      "en": [
        "The Lord be with you.",
        "And with your spirit.",
        "Lift up your hearts.",
        "We lift them up to the Lord.",
        "Let us give thanks to the Lord our God.",
        "It is right and just."
      ],
      "la": [
        "Dóminus vobíscum.",
        "Et cum spíritu tuo.",
        "Sursum corda.",
        "Habémus ad Dóminum.",
        "Grátias agámus Dómino Deo nostro.",
        "Dignum et iustum est."
      ]
    }
  },
