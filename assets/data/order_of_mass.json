  {
    "id": "eucharistic_prayer_acclamation",
    "title": "Mystery of Faith Acclamation",
    "insertionPoint": "acclamation",
    "order": 1,
    "availableLanguages": ["en", "la", "es", "pt", "fr", "tl", "it", "pl", "vi", "ko"],
    "conditions": ["always"],
    "isOptional": false,
    "isDialogue": true,
    "dialogueStructure": {
      "en": [
        {"text": "The mystery of faith.", "role": "priest", "prefix": "V"},
        {"text": "We proclaim your Death, O Lord, and profess your Resurrection until you come again.", "role": "people", "prefix": "R"}
      ],
      "la": [
        {"text": "Mystérium fídei.", "role": "priest", "prefix": "V"},
        {"text": "Annuntiamus mortem tuam, Dómine, confitémur resurrectiónem tuam, donec venias.", "role": "people", "prefix": "R"}
      ],
      "it": [
        {"text": "Mistero della fede.", "role": "priest", "prefix": "V"},
        {"text": "Annunciamo la tua morte, Signore, e professiamo la tua risurrezione.", "role": "people", "prefix": "R"}
      ],
      "pl": [
        {"text": "Tajemnica wiary.", "role": "priest", "prefix": "V"},
        {"text": "G?osimy Twoj? ?mier?, Panie, i wyznajemy Twoje zmartwychwstanie.", "role": "people", "prefix": "R"}
      ],
      "vi": [
        {"text": "Bí ?n c?a tin lành.", "role": "priest", "prefix": "V"},
        {"text": "Chúng tôi công b? cái ?c? c?a Chúa.", "role": "people", "prefix": "R"}
      ],
      "ko": [
        {"text": "Sin-ui bimil.", "role": "priest", "prefix": "V"},
        {"text": "Jesu-ui jug-eul al-ligo.", "role": "people", "prefix": "R"}
      ]
    },
    "contentByLanguage": {
      "en": [
        "The mystery of faith.",
        "We proclaim your Death, O Lord, and profess your Resurrection until you come again."
      ],
      "la": [
        "Mystérium fídei.",
        "Annuntiamus mortem tuam, Dómine, confitémur resurrectiónem tuam, donec venias."
      ]
    }
  },
  {
    "id": "final_doxology",
    "title": "Final Doxology",
    "insertionPoint": "acclamation",
    "order": 2,
    "availableLanguages": ["en", "la", "es", "pt", "fr", "tl", "it", "pl", "vi", "ko"],
    "conditions": ["always"],
    "isOptional": false,
    "isDialogue": true,
    "dialogueStructure": {
      "en": [
        {"text": "Through him, and with him, and in him, O God, almighty Father, in the unity of the Holy Spirit, all glory and honor is yours, for ever and ever.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ],
      "la": [
        {"text": "Per ipsum, et cum ipso, et in ipso, Dómine, Deus Pater omnípotens, in unitáte Spíritus Sancti, omnis honor et glória tua, per ómnia sæcula sæculórum.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ],
      "it": [
        {"text": "Per lui, con lui e in lui, Dio Padre onnipotente, nell'unità dello Spirito Santo, ogni gloria e onore.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ],
      "pl": [
        {"text": "Przez Niego, z Nim i w Nim, Bo?e Ojciec wszechmog?cy.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ],
      "vi": [
        {"text": "Nguyen Ngai, cung Ngai, trong Ngai.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ],
      "ko": [
        {"text": "Geu-eul tonghae, geu-wa hamkkeh, geu-an-eseo.", "role": "priest", "prefix": "V"},
        {"text": "Amen.", "role": "people", "prefix": "R"}
      ]
    },
    "contentByLanguage": {
      "en": [
        "Through him, and with him, and in him, O God, almighty Father, in the unity of the Holy Spirit, all glory and honor is yours, for ever and ever.",
        "Amen."
      ],
      "la": [
        "Per ipsum, et cum ipso, et in ipso, Dómine, Deus Pater omnípotens, in unitáte Spíritus Sancti, omnis honor et glória tua, per ómnia sæcula sæculórum.",
        "Amen."
      ]
    }
  },
